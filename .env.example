# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public base URL of this deployment.
# development: http://localhost:3000
# staging/production: https://your-domain.example
APP_URL=http://localhost:3000

# Runtime mode used by Node/Next.js. Allowed: development, test, production.
NODE_ENV=development

# Business environment used to isolate development, staging, and production.
APP_ENV=development

# Neon/Postgres connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# Auth: better-auth, Google OAuth, Resend Email OTP/Magic Link
# -----------------------------------------------------------------------------
# Random secret for better-auth session/signing.
# Use a long random value, e.g. openssl rand -base64 32.
BETTER_AUTH_SECRET=

# Canonical auth URL for callbacks. Usually same as APP_URL.
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth client credentials from Google Cloud Console.
# Callback URL must match the better-auth route configured in the app.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend API key for email OTP/Magic Link.
RESEND_API_KEY=

# Sender email. Format: "RunwayTools <login@your-domain.example>".
EMAIL_FROM=

# Inbox for likeness, copyright, trademark, privacy, and takedown notices.
LEGAL_CONTACT_EMAIL=

# Comma-separated admin/operator email allowlist for the admin backend.
# Example: admin@example.com,operator@example.com
ADMIN_EMAIL_ALLOWLIST=

# -----------------------------------------------------------------------------
# Creem: checkout, webhook, prompt moderation
# -----------------------------------------------------------------------------
# Creem API base URL.
# Sandbox/test: https://test-api.creem.io
# Production: https://api.creem.io
CREEM_BASE_URL=https://test-api.creem.io

# Creem checkout/payment API key.
CREEM_API_KEY=

# Secret used to verify Creem webhook signatures.
CREEM_WEBHOOK_SECRET=

# Prompt moderation mode.
# Allowed values:
# - creem:
#   Default and recommended for any shared/staging/production environment.
#   Calls Creem POST /v1/moderation/prompt and fails closed on error.
#   Requires CREEM_MODERATION_API_KEY to be configured.
# - dev_bypass:
#   Development/test-only bypass for local work before a Creem moderation store/key
#   is ready. Prompts are recorded as allow without calling Creem.
#   This mode is rejected outside NODE_ENV=development or test.
# - off:
#   Explicitly disables prompt moderation and records allow without calling Creem.
#   Use only when you intentionally want no NSFW/prompt validation at all.
#   This is more dangerous than dev_bypass because it can also be enabled outside
#   local development.
PROMPT_MODERATION_MODE=creem

# Creem moderation key for POST /v1/moderation/prompt.
# Required when PROMPT_MODERATION_MODE=creem.
# Not required when PROMPT_MODERATION_MODE=dev_bypass or off.
# Prompt moderation must fail closed when this is missing in production while
# using PROMPT_MODERATION_MODE=creem.
# This is sent server-side as x-api-key and must never be exposed to the browser.
CREEM_MODERATION_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2
# -----------------------------------------------------------------------------
# Cloudflare account id that owns the R2 bucket.
CLOUDFLARE_R2_ACCOUNT_ID=

# R2 access key pair. Grant only the bucket permissions required by this app.
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Private R2 bucket name. The bucket must not be public.
CLOUDFLARE_R2_BUCKET=

# Optional CDN/public base URL if a private download proxy/CDN is introduced.
# Do not store permanent public file URLs for user assets.
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Internal workers and cron
# 生成方式： node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# -----------------------------------------------------------------------------
# Shared secret for internal app-to-worker endpoints.
INTERNAL_WORKER_SECRET=

# Secret expected by /api/internal/worker/tick from cron-job.org.
CRON_JOB_SECRET=

# HMAC secret for hashing trial-abuse signals. Required outside local development.
ABUSE_HASH_SECRET=

# Cloud Run stitch-worker invoke URL.
# Example: https://stitch-worker-xxxxx-region.a.run.app
CLOUD_RUN_STITCH_URL=

# Secret used by the main app and Cloud Run stitch-worker callbacks.
CLOUD_RUN_STITCH_SECRET=

# -----------------------------------------------------------------------------
# AI providers: DeepSeek, vision model, moderation model
# -----------------------------------------------------------------------------
# DeepSeek key for storyboard/prompt generation.
DEEPSEEK_API_KEY=

# DeepSeek OpenAI-compatible base URL.
# Leave empty to use https://api.deepseek.com.
DEEPSEEK_BASE_URL=

# DeepSeek model for storyboard JSON generation.
# Default: deepseek-v4-flash.
DEEPSEEK_STORYBOARD_MODEL=deepseek-v4-flash

# Vision provider identifier. Allowed values: openai, apimart, evolink, custom.
# Unknown values are treated as unavailable and must never return fake success.
VISION_PROVIDER=

# API key for the selected vision provider.
VISION_API_KEY=

# Base URL for OpenAI-compatible/custom vision providers.
# openai: leave empty to use https://api.openai.com/v1.
# apimart/evolink/custom: must be the provider's OpenAI-compatible /v1 base URL.
VISION_BASE_URL=

# Lite model for low-cost asset precheck.
# Example values: gpt-5.4-nano or provider-equivalent model id.
VISION_MODEL_LITE=

# Standard model for normal asset analysis and default post-QA.
# Example values: gpt-5.4-mini or provider-equivalent model id.
VISION_MODEL_STANDARD=

# Strict model for high-risk asset review, human/back-view tasks, and appeals.
# Example values: gpt-5.5 or provider-equivalent model id.
VISION_MODEL_STRICT=

# Text/content safety moderation model. Default from PRD/SPEC.
OPENAI_MODERATION_MODEL=omni-moderation-latest

# -----------------------------------------------------------------------------
# Video provider endpoints
# -----------------------------------------------------------------------------
# EvoLink API base URL, provided by EvoLink account/API docs.
# Use the service root, for example: https://api.evolink.ai
# Do not paste the full endpoint path like /v1/videos/generations here.
EVOLINK_BASE_URL=
EVOLINK_API_KEY=

# APIMart API base URL.
APIMART_BASE_URL=
APIMART_API_KEY=

# -----------------------------------------------------------------------------
# Legacy EvoLink retry controls
# Added: 2026-06-11
# -----------------------------------------------------------------------------
# Legacy compatibility only. Prefer VIDEO_GENERATION_SUBMIT_MAX_ATTEMPTS below.
# Max attempts for one EvoLink video generation submit call.
# Default in code: 3.
# This retries transient network/provider submission failures before the segment
# is marked as submit failed.
EVOLINK_SUBMIT_MAX_ATTEMPTS=3

# Legacy compatibility only. Prefer VIDEO_GENERATION_TASK_MAX_REGENERATIONS below.
# Max total provider task generations for one segment after task-level failure.
# Default in code: 2.
# Example: 2 means the first provider task failure will automatically re-submit
# the segment once; a second task failure marks the segment/job failed.
# Keep this small to avoid repeated provider cost.
EVOLINK_TASK_MAX_REGENERATIONS=2

# -----------------------------------------------------------------------------
# Video generation router
# Added: 2026-06-11
# -----------------------------------------------------------------------------
# MVP server-side video generation provider/model/key selection is env-only.
# Database model_routes/provider_keys do not decide the video generation
# provider, model, or vendor API key.
# Allowed providers: apimart, evolink.
VIDEO_GENERATION_PROVIDER=apimart
VIDEO_GENERATION_MODEL=pixverse-v6

# Enables creation of new 40-second paid Beta jobs.
# Existing jobs continue even if this is later disabled.
VIDEO_DURATION_40_ENABLED=false

# Optional local cost-saving override for video segment resolution.
# Leave empty for profile defaults: trial=540p, paid=720p/1080p.
# Allowed values: 360p, 540p, 720p, 1080p.
# Use this instead of hardcoding resolution inside provider adapters, so DB
# segment records, provider logs, and vendor requests stay consistent.
VIDEO_GENERATION_DEBUG_RESOLUTION=

# Generic max attempts for one video generation submit call.
# Default in code: 3.
# Takes precedence over EVOLINK_SUBMIT_MAX_ATTEMPTS.
# Keep this small because every successful submit can create provider cost.
VIDEO_GENERATION_SUBMIT_MAX_ATTEMPTS=3

# Generic max total provider task generations for one segment after task-level
# failure. Default in code: 2.
# Takes precedence over EVOLINK_TASK_MAX_REGENERATIONS.
# Example: 2 means one automatic re-submit after the first provider task fails.
VIDEO_GENERATION_TASK_MAX_REGENERATIONS=2
